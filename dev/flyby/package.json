{
  "name": "flyby",
  "description": "Location reviews demo (Flyby GraphQL) for Apollo workshops.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@apollo/client-ai-apps": "^0.7.0",
    "@apollo/space-kit": "^9.3.1",
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@graphql-tools/graphql-tag-pluck": "^8.3.23",
    "@modelcontextprotocol/ext-apps": "^1.1.0",
    "framer-motion": "^4.1.17",
    "graphql": "^16.12.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^4.3.1",
    "react-rating-stars-component": "^2.2.0",
    "react-router-dom": "^6.30.3",
    "rxjs": "^7.8.2",
    "web-vitals": "^1.1.2"
  },
  "scripts": {
    "dev": "vite",
    "dev:mcp": "cross-env TARGET=mcp vite",
