    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "cross-env": "^10.1.0",
    "jsdom": "^23.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^4.0.15"
  },
  "overrides": {
    "posthog-node": "5.21.0",
